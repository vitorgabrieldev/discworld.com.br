# Discord OAuth App — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3001/auth/callback

# Discord Bot Token (for reading guild channels/roles)
DISCORD_BOT_TOKEN=

# LiveKit — https://cloud.livekit.io or self-hosted
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# App
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development

# Session
COOKIE_SECRET=change-this-to-something-random-in-production

# Database (optional for MVP, will be needed for persistence)
DATABASE_URL=postgresql://discworld:discworld@localhost:5432/discworld
